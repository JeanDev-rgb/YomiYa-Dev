<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:navigation="clr-namespace:YomiYa.Features.Navigation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="navigation:SideBarMenuViewModel"
             x:Class="YomiYa.Features.Navigation.SideBarMenuView">

    <Design.DataContext>
        <navigation:SideBarMenuViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.HamburgerButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="6 10" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.HamburgerButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="12 10" />
            <Setter Property="Margin" Value="6 0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0.15" />
                    <BrushTransition Property="BorderBrush" Duration="0.15" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        </Style>

        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="2 0 0 0" />
        </Style>

        <Style Selector="ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="ListBoxItem:selected PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
        </Style>
    </UserControl.Styles>

    <SplitView IsPaneOpen="{Binding IsPaneOpen}"
               CompactPaneLength="48"
               OpenPaneLength="164"
               Background="{DynamicResource ControlFillColorDefaultBrush}"
               PaneBackground="{DynamicResource ControlFillColorDefaultBrush}"
               DisplayMode="CompactInline">

        <SplitView.Pane>
            <StackPanel Spacing="5" Margin="0 2" HorizontalAlignment="Left" MinWidth="125">
                <Button Classes="HamburgerButton" Command="{Binding TriggerPaneCommand}">
                    <PathIcon Height="12" Data="{StaticResource LineHorizontal3Regular}" />
                </Button>

                <ListBox ItemsSource="{Binding Items}"
                         SelectedItem="{Binding SelectedListItem}"
                         SelectedIndex="0"
                         Background="Transparent"
                         Padding="0"
                         Margin="0 0 -40 0">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type navigation:ListItemTemplate}">
                            <StackPanel Spacing="16" Orientation="Horizontal" VerticalAlignment="Center">
                                <PathIcon Width="16" Data="{Binding ListItemIcon}" />
                                <TextBlock Text="{Binding Label}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </SplitView.Pane>

        <SplitView.Content>
            <Border CornerRadius="12 0 0 0"
                    Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
                    Padding="12">
                <TransitioningContentControl Content="{Binding CurrentPage}">
                    <TransitioningContentControl.PageTransition>
                        <CrossFade Duration="0:0:0.5" />
                    </TransitioningContentControl.PageTransition>
                </TransitioningContentControl>
            </Border>
        </SplitView.Content>
    </SplitView>
</UserControl>