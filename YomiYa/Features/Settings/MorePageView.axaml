<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="650"
             xmlns:settings="clr-namespace:YomiYa.Features.Settings"
             x:DataType="settings:MorePageViewModel"
             x:Class="YomiYa.Features.Settings.MorePageView">

    <Design.DataContext>
        <settings:MorePageViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="TextBlock.PageTitle">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Light" />
            <Setter Property="Margin" Value="0 0 0 20" />
        </Style>
        <Style Selector="Expander">
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="0 5" />
        </Style>
        <Style Selector="Expander /template/ ToggleButton">
            <Setter Property="Padding" Value="16" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.FormFieldLabel">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style Selector="ComboBox.Settings">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style Selector="TextBox.Settings">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="MinWidth" Value="250" />
        </Style>
        <Style Selector="Button.PrimaryAction">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
            <Setter Property="Padding" Value="16 8" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.SecondaryAction">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16 8" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Button.SecondaryAction:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <Border Background="{DynamicResource ApplicationPageBackgroundThemeBrush}" Padding="32">
            <StackPanel Spacing="10" MaxWidth="700">
                <TextBlock Classes="PageTitle" Text="{Binding AdditionalSettingsText}" />

                <Expander Header="{Binding ApplicationThemeText}">
                    <StackPanel Spacing="10" Margin="16 0 16 16">
                        <ComboBox Classes="Settings" ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding SelectedTheme}" />
                        <Button Content="{Binding ImportThemeText}"
                                Command="{Binding ImportThemeCommand}"
                                HorizontalAlignment="Left"
                                Classes="SecondaryAction" />
                    </StackPanel>
                </Expander>

                <Expander Header="{Binding ApplicationLanguageText}">
                    <StackPanel Margin="16 0 16 16">
                        <ComboBox Classes="Settings" ItemsSource="{Binding Languages}"
                                  SelectedItem="{Binding SelectedLanguage}" />
                    </StackPanel>
                </Expander>

                <Expander Header="{Binding CloudSynchronizationText}">
                    <StackPanel Spacing="15" Margin="16 0 16 16">
                        <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto" VerticalAlignment="Center">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                <Button Classes="SecondaryAction"
                                        Content="{Binding SignInWithGoogleDriveText}"
                                        Command="{Binding LoginGoogleCommand}"
                                        IsVisible="{Binding !IsAuthenticated}" />
                                <Button Classes="SecondaryAction"
                                        Content="{Binding SignOutText}"
                                        Command="{Binding LogoutGoogleCommand}"
                                        IsVisible="{Binding IsAuthenticated}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SyncStatusMessage}"
                                       VerticalAlignment="Center"
                                       Margin="15,0,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsAuthenticated}">
                            <Button Classes="SecondaryAction"
                                    Content="{Binding UploadBackupText}"
                                    Command="{Binding UploadBackupCommand}" />
                            <Button Classes="SecondaryAction"
                                    Content="{Binding RestoreBackupText}"
                                    Command="{Binding RestoreBackupCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <Expander Header="{Binding ManualProxyConfigurationText}">
                    <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="16 0 16 16">
                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="FormFieldLabel" Text="{Binding HostText}"
                                   Margin="5" />
                        <TextBox Grid.Row="0" Grid.Column="1" Classes="Settings" Text="{Binding ProxyHost}" Margin="5" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="FormFieldLabel" Text="{Binding PortText}"
                                   Margin="5" />
                        <TextBox Grid.Row="1" Grid.Column="1" Classes="Settings" Text="{Binding ProxyPort}" Margin="5" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="FormFieldLabel"
                                   Text="{Binding UsernameOptionalText}" Margin="5" />
                        <TextBox Grid.Row="2" Grid.Column="1" Classes="Settings" Text="{Binding ProxyUsername}"
                                 Margin="5" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Classes="FormFieldLabel" Text="{Binding PasswordText}"
                                   Margin="5" />
                        <TextBox Grid.Row="3" Grid.Column="1" Classes="Settings" Text="{Binding ProxyPassword}"
                                 PasswordChar="*" Margin="5" />

                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"
                                    Spacing="10" Margin="0 10 0 0">
                            <Button Classes="SecondaryAction" Content="{Binding ResetText}"
                                    Command="{Binding ResetProxyCommand}" />
                            <Button Classes="PrimaryAction" Content="{Binding SaveText}"
                                    Command="{Binding SaveProxyCommand}" />
                        </StackPanel>
                    </Grid>
                </Expander>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>