<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        xmlns:reader="clr-namespace:YomiYa.Features.Reader"
        x:Class="YomiYa.Features.Reader.ReaderView"
        x:DataType="reader:ReaderViewModel"
        WindowState="FullScreen"
        Background="#1C1C1C"
        Title="ReaderView">

    <Design.DataContext>
        <reader:ReaderViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.ReaderBar">
            <Setter Property="Background" Value="#D0181818" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0.3" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Grid.ReaderContainer.controls-visible Border.TopBar">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Grid.ReaderContainer.controls-visible Border.BottomBar">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.ReaderNav">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#EAEAEA" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style Selector="Button.ReaderNav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3A3A" />
        </Style>

        <Style Selector="Grid.ReaderContainer Image">
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
        <Style Selector="Grid.ReaderContainer.wide-mode Image">
            <Setter Property="Stretch" Value="UniformToFill" />
        </Style>
        <Style Selector="Grid.ReaderContainer:not(.wide-mode) ItemsControl[Name=CascadeItemsControl] Image">
            <Setter Property="MaxWidth" Value="{Binding $parent[Window].Bounds.Width, Converter={StaticResource HalfValueConverter}}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.ChapterTitle">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.PageInfo">
            <Setter Property="Foreground" Value="#9E9E9E" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="ProgressBar">
            <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="MaxWidth" Value="300" />
        </Style>
        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
        </Style>
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *, Auto" Classes="ReaderContainer" x:Name="ReaderContainerGrid"
          Classes.wide-mode="{Binding ReadingWidth, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Wide}">

        <Grid Grid.Row="0" Grid.RowSpan="3">
            <Carousel ItemsSource="{Binding Pages}"
                      SelectedIndex="{Binding CurrentPageIndex, Mode=TwoWay}"
                      IsVisible="{Binding ReadingMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Paginated}">
                <Carousel.ItemTemplate>
                    <DataTemplate>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Image Source="{Binding Data}" />
                        </ScrollViewer>
                    </DataTemplate>
                </Carousel.ItemTemplate>
            </Carousel>

            <ScrollViewer x:Name="CascadeScrollViewer"
                          IsVisible="{Binding ReadingMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Cascade}">
                <ItemsControl x:Name="CascadeItemsControl"
                              ItemsSource="{Binding Pages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Data}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <ProgressBar IsIndeterminate="True" VerticalAlignment="Center" IsVisible="{Binding IsLoading}" />
        </Grid>

        <Border Grid.Row="0" Classes="ReaderBar TopBar" BorderThickness="0,0,0,1" BorderBrush="#333">
            <Border Padding="10,5">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Button Grid.Column="0" Classes="ReaderNav" Content="&lt; Cap. Anterior"
                            Command="{Binding PreviousChapterCommand}" />
                    <TextBlock Grid.Column="1" Classes="ChapterTitle" Text="{Binding SelectedChapter.Name}" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5">
                        <Button Classes="ReaderNav" Content="Cap. Siguiente &gt;"
                                Command="{Binding NextChapterCommand}" />
                        <Button Classes="ReaderNav" Content="Modo" Command="{Binding ToggleReadingModeCommand}" />
                        <Button Classes="ReaderNav" Content="Ancho" Command="{Binding ToggleReadingWidthCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Grid.Row="2" Classes="ReaderBar BottomBar" BorderThickness="0,1,0,0" BorderBrush="#333"
                IsVisible="{Binding ReadingMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Paginated}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,10">
                <Button Classes="ReaderNav" Content="&lt; Anterior" Command="{Binding PreviousPageCommand}" />
                <TextBlock Classes="PageInfo" Text="{Binding PageInfo}" />
                <Button Classes="ReaderNav" Content="Siguiente &gt;" Command="{Binding NextPageCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>