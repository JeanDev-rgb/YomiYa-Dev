    <Design.PreviewWith>
        <StackPanel Orientation="Horizontal" Spacing="10">
            <StackPanel Spacing="10">
                <PathIcon Data="{StaticResource LineHorizontal3Regular}" />
                <PathIcon Data="{StaticResource Browse}" />
                <PathIcon Data="{StaticResource History}" />
                <PathIcon Data="{StaticResource SearchRegular}" />
            </StackPanel>
            <StackPanel Spacing="10">
                <PathIcon Data="{StaticResource Library}" />
                <PathIcon Data="{StaticResource More}" />
                <PathIcon Data="{StaticResource Updates}" />
                <PathIcon Data="{StaticResource ArrowLeft}" />
            </StackPanel>
            <StackPanel Spacing="10">
                <PathIcon Data="{StaticResource CoverError}" />
                <PathIcon Data="{StaticResource Dollar}" />
                <PathIcon Data="{StaticResource HeartFilled}" />
                <PathIcon Data="{StaticResource ArrowRight}" />
            </StackPanel>
            <StackPanel Spacing="10">
                <PathIcon Data="{StaticResource FilterRegular}" />
                <PathIcon Data="{StaticResource TrashIcon}" />
                <PathIcon Data="{StaticResource SettingsRegular}" />
                <PathIcon Data="{StaticResource DeleteRegular}" />
            </StackPanel>
            <StackPanel Spacing="10">
                <PathIcon Data="{StaticResource ArrowRightRegular}" />
            </StackPanel>
        </StackPanel>
    </Design.PreviewWith>

